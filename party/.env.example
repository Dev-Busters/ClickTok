# 4.5b: durable leaderboard (lobby reads/writes Supabase's `leaderboard_scores`
# table with the service role key, bypassing RLS). Both optional — when unset,
# the lobby falls back to its pre-4.5b in-memory-only leaderboard.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# 6.7: optional telemetry — without these the party rooms run with zero tracking noise.
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com
